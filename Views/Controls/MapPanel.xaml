<UserControl x:Class="Map.Views.Controls.MapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Map.Views.Controls"
             mc:Ignorable="d" 
             >
    <!-- 지도 -->
    <Grid Width="800" Height="590">
        <Image Source="pack://application:,,,/Map;component/images/map2.png"
             Stretch="Fill"
             SnapsToDevicePixels="True"/>

        <Canvas x:Name="MapCanvas"
              Background="Transparent"
              MouseDown="MapCanvas_MouseDown">
            <Image Height="79" Canvas.Left="74" Canvas.Top="208" Width="52" Source="pack://application:,,,/Map;component/images/station2.png" Margin="-3,1,0,0"/>
            <Image Height="79" Canvas.Left="414" Canvas.Top="484" Width="52" Source="pack://application:,,,/Map;component/images/station2.png" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,8,0,0"/>
            <Image Height="79" Canvas.Left="652" Canvas.Top="20" Width="52" Source="pack://application:,,,/Map;component/images/station2.png" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0"/>
            
            <Image Height="26" Canvas.Left="533" Canvas.Top="128" Width="26" Source="pack://application:,,,/Map;component/images/bridge2.png" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image Height="26" Canvas.Left="574" Canvas.Top="103" Width="26" Source="pack://application:,,,/Map;component/images/bridge2.png" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image Height="26" Canvas.Left="180" Canvas.Top="348" Width="26" Source="pack://application:,,,/Map;component/images/bridge2.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Image Height="23" Canvas.Left="661" Canvas.Top="78" Width="43" Source="pack://application:,,,/Map;component/images/가은역.png"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Image Height="20" Canvas.Left="67" Canvas.Top="199.605" Width="60" Source="pack://application:,,,/Map;component/images/구량리역.png" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        </Canvas>
    </Grid>
</UserControl>
