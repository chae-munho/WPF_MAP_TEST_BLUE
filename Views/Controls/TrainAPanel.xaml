<UserControl x:Class="Map.Views.Controls.TrainAPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Map.Views.Controls"
             mc:Ignorable="d" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
           >
    <!-- 필요하면 UserControl 자체 리소스로도 보유(부모 Window 리소스 써도 되지만 안전하게 포함) -->
    <UserControl.Resources>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Dinmed"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TimeStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Dinmed"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <BitmapImage x:Key="DefaultLockIcon"
                 UriSource="pack://application:,,,/Map;component/images/lock2.png"/>
    </UserControl.Resources>

    <StackPanel Grid.Column="0"
    Margin="20,0,20,15"
    VerticalAlignment="Top">

     
        <Grid Width="420" Height="305" Margin="0,0,0,20">
            <Border Width="420" Height="305"
            Background="#111327"
            CornerRadius="10">

               
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                      
                        <RowDefinition Height="*"/>
                       
                    </Grid.RowDefinitions>

                   
                    <Border Grid.Row="0"
                    Background="#3E6AA0"
                    CornerRadius="10,10,0,0">
                        <TextBlock Text="가은역 방면"
                           Foreground="#FFF"
                           FontFamily="Dinmed"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>

                  
                    <Grid Grid.Row="1" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                      
                        <Grid Grid.Column="0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Width="250">

                            <Image Source="pack://application:,,,/Map;component/images/gaze2.png"
                           Width="233"
                           Height="193"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                         
                            <Image Source="pack://application:,,,/Map;component/images/gaze2.png"
                           Width="233"
                           Height="193"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Clip="{Binding TrainA.GaugeClip}"/>

                        
                            <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontFamily="Dinmed"
                               TextAlignment="Center"
                               Margin="0,-28,0,0">
                        <Run Text="{Binding TrainA.MotorSpeed, FallbackValue='0', TargetNullValue='0'}"
                             FontSize="28"
                             FontWeight="Bold"/>
                        <Run Text="km/h"
                             FontSize="15"/>
                            </TextBlock>

                         
                            <Image Source="pack://application:,,,/Map;component/images/niddle2.png"
                           Width="21"
                           Height="70"
                           RenderTransformOrigin="0.48,0.84"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,100,0,0">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="{Binding TrainA.NeedleAngle}"/>
                                </Image.RenderTransform>
                            </Image>

                            <Label Content="0"  HorizontalAlignment="Left" Margin="60,153,0,0" VerticalAlignment="Top" Foreground="#FF6F88A3" FontSize="10"/>
                            
                            <Label Content="15" HorizontalAlignment="Center" Margin="0,30,0,0" VerticalAlignment="Top" Foreground="#FF6F88A3" FontSize="10"/>
                           
                            <Label Content="30" HorizontalAlignment="Left" Margin="167,153,0,0" VerticalAlignment="Top" Foreground="#FF6F88A3" FontSize="10"/>
                        </Grid>

                   
                        <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                        
                            <Button Width="98" Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,5"
                            Command="{Binding ToggleLockACommand}">
                                <Grid>
                                    <Image Source="pack://application:,,,/Map;component/images/firstButton2.png" Stretch="Fill"/>
                                    <Image Source="{Binding TrainA.LockIcon, TargetNullValue={StaticResource DefaultLockIcon},
                                            FallbackValue={StaticResource DefaultLockIcon}}"
                                   Width="18" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                       
                            <Button Width="98" Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,5"
                            IsEnabled="{Binding TrainA.ControlsEnabled}"
                            Opacity="{Binding TrainA.ControlsOpacity}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding TrainAForwardDownCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseUp">
                                        <i:InvokeCommandAction Command="{Binding TrainAForwardUpCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>

                                <Grid>
                                    <Image Source="pack://application:,,,/Map;component/images/secondButton2.png" Stretch="Fill"/>
                                    <Image Source="pack://application:,,,/Map;component/images/up2.png"
                                   Width="18" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                         
                            <Button Width="98" Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,5"
                            IsEnabled="{Binding TrainA.ControlsEnabled}"
                            Opacity="{Binding TrainA.ControlsOpacity}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding TrainABackwardDownCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseUp">
                                        <i:InvokeCommandAction Command="{Binding TrainABackwardUpCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>

                                <Grid>
                                    <Image Source="pack://application:,,,/Map;component/images/secondButton2.png" Stretch="Fill"/>
                                    <Image Source="pack://application:,,,/Map;component/images/down2.png"
                                   Width="18" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                         
                            <Button Width="98" Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,5"
                            IsEnabled="{Binding TrainA.ControlsEnabled}"
                            Opacity="{Binding TrainA.ControlsOpacity}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding TrainABreakDownCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseUp">
                                        <i:InvokeCommandAction Command="{Binding TrainABreakUpCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>

                                <Grid>
                                    <Image Source="pack://application:,,,/Map;component/images/secondButton2.png" Stretch="Fill"/>
                                    <Image Source="pack://application:,,,/Map;component/images/pause2.png"
                                   Width="18" Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

          
            <Border Background="#80000000"
            CornerRadius="10"
            Visibility="{Binding A1Blackout, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
            IsHitTestVisible="False"/>
        </Grid>



     
        <Grid Width="420" Height="265" Margin="0,0,0,20">
            <Border Width="420" Height="265"
            Background="#111327"
            CornerRadius="10">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                   
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Motor -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                  
                    <StackPanel Grid.Row="0">
                     
                        <Grid Margin="0,20,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                               Text="전압(V)"
                               Foreground="White"
                               FontFamily="Dinmed"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Left" Margin="22,9,0,-9"/>

                            <TextBlock
                               Text="{Binding TrainA.VoltageBar.ValueText, FallbackValue='0', TargetNullValue='0'}"
                               Foreground="White"
                               FontFamily="Dinmed"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Left" Margin="325,1,0,-1"/>
                        </Grid>

                     
                        <Grid Height="25" Width="350" HorizontalAlignment="Center">
                        
                            <Border Background="#2A2E45"
                            CornerRadius="10"/>

                        
                            <Border Background="#4CC3FF"
                            CornerRadius="10"
                            HorizontalAlignment="Left"
                            Width="{Binding TrainA.VoltageBar.BarWidth}"
                            ClipToBounds="True"/>
                        </Grid>

                     
                        <Grid Width="350" Margin="0,6,0,0" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="0"   Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="90"  Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Center" Margin="-30,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="180" Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="270" Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Center" Margin="30,0,0,0"/>
                            <TextBlock Grid.Column="4" Text="350" Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!--  모터출력(A)  -->
                    <StackPanel Grid.Row="2">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                               Text="모터출력(A)"
                               Foreground="White"
                               FontFamily="Dinmed"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Left" Margin="22,9,0,-9"/>

                            <TextBlock
                               Text="{Binding TrainA.MotorOutputBar.ValueText, FallbackValue='0', TargetNullValue='0'}"
                               Foreground="White"
                               FontFamily="Dinmed"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Left" Margin="325,1,0,-1"/>
                        </Grid>

                   
                        <Grid Height="25" Width="350" HorizontalAlignment="Center">
                        
                            <Border Background="#2A2E45"
                            CornerRadius="10"/>

                        
                            <Border Background="#4CC3FF"
                            CornerRadius="10"
                            HorizontalAlignment="Left"
                            Width="{Binding TrainA.MotorOutputBar.BarWidth}"
                            ClipToBounds="True"/>
                        </Grid>

                     
                        <Grid Width="350" Margin="0,6,0,0" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="0"   Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="60"  Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Center" Margin="-30,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="120" Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="180" Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Center" Margin="30,0,0,0"/>
                            <TextBlock Grid.Column="4" Text="250" Foreground="#FFF" FontFamily="Dinmed" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- blackout overlay (A2) -->
            <Border Background="#80000000"
            CornerRadius="10"
            Visibility="{Binding A2Blackout, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
            IsHitTestVisible="False"/>
        </Grid>

        <!-- Rect 3 : 배터리 / 온도 A  -->
        <Grid Width="420" Height="267" Margin="0,0,0,0">
            <Border Width="420" Height="267"
            Background="#111327"
            CornerRadius="10">
                <Grid Margin="20,20,10,20">
                    <Grid.Resources>
                        <Style x:Key="TitleText" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontFamily" Value="Noto Sans KR"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                        </Style>

                        <Style x:Key="CenterValue" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontFamily" Value="Dinmed"/>
                            <Setter Property="FontSize" Value="23"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>

                        <Style x:Key="UnitValue" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontFamily" Value="Dinmed"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="3,0,0,0"/>
                        </Style>
                    </Grid.Resources>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3"/>

                    </Grid.ColumnDefinitions>

              
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="-21,0,0,0">
                        <TextBlock Text="배터리 용량(%)" Style="{StaticResource TitleText}"/>
                        <Grid Width="170" Height="170">
                            <Image Source="pack://application:,,,/Map;component/images/firstBattery2.png"
                           Width="170" Height="170"
                           RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="{Binding TrainA.BatteryRotateAngle}"/>
                                </Image.RenderTransform>
                            </Image>

                            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                                <TextBlock Text="{Binding TrainA.Battery, TargetNullValue='0', FallbackValue='0'}" Style="{StaticResource CenterValue}"/>
                                <TextBlock Text="%" Style="{StaticResource UnitValue}"/>
                            </StackPanel>
                        </Grid>

                        <Button Width="86" Height="26"
                        Margin="5,4,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                            <Grid>
                                <Image Source="pack://application:,,,/Map;component/images/bellButton2.png" Stretch="Fill"/>
                                <Image Source="pack://application:,,,/Map;component/images/notice2.png"
                               Width="16" Height="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                 
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="-14,0,0,0">
                        <TextBlock Text="배터리 온도(℃)" Style="{StaticResource TitleText}"/>
                        <Grid Width="158" Height="156">
                            <Image Source="pack://application:,,,/Map;component/images/secondBattery2.png"
                           Width="158" Height="156"
                           RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="{Binding TrainA.BatteryTempRotateAngle}"/>
                                </Image.RenderTransform>
                            </Image>

                            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                                <TextBlock Text="{Binding TrainA.BatteryTemp, TargetNullValue='0', FallbackValue='0'}" Style="{StaticResource CenterValue}"/>
                                <TextBlock Text="°C" Style="{StaticResource UnitValue}"/>
                            </StackPanel>
                        </Grid>

                        <Button Width="86" Height="26"
                        Margin="0,19,-5,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                            <Grid>
                                <Image Source="pack://application:,,,/Map;component/images/bellButton2.png" Stretch="Fill"/>
                                <Image Source="pack://application:,,,/Map;component/images/notice2.png"
                               Width="16" Height="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                
                </Grid>
            </Border>

            <!-- blackout overlay (A3) -->
            <Border Background="#80000000"
            CornerRadius="10"
            Visibility="{Binding A3Blackout, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
            IsHitTestVisible="False"/>
        </Grid>
    </StackPanel>
</UserControl>
