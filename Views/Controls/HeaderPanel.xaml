<UserControl x:Class="Map.Views.Controls.HeaderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Map.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="1750">

    <Border Grid.Row="0"
            Height="60"
            Background="#111327"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.1"
                              ShadowDepth="0"
                              BlurRadius="10" />
        </Border.Effect>

        <Grid Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CENTER -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Map;component/images/header.png"
                       Width="132"
                       Height="33"
                       Stretch="Uniform"/>

                <TextBlock Text="테마열차 관제 및 차량 제어 시스템"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- RIGHT -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button Content="관리자 설정"
                        Width="110"
                        Height="34"
                        Margin="0,0,12,0"
                        Background="#3E6AA0"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding OpenAdminSettingsCommand}"/>

                <TextBlock Foreground="White"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Text="{Binding TimeText,
                                          RelativeSource={RelativeSource AncestorType=UserControl},
                                          FallbackValue=0000년 00월 00일 - 00:00:00,
                                          TargetNullValue=0000년 00월 00일 - 00:00:00}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>