<UserControl x:Class="Map.Views.Controls.HeaderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Map.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="1750">
    <!-- HEADER START-->
    <Border Grid.Row="0"
        Height="60"
        Background="#111327"
        SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect Color="Black"
                  Opacity="0.1"
                  ShadowDepth="0"
                  BlurRadius="10" />
        </Border.Effect>

        <Grid Margin="20,0">

            <!-- 2개 컬럼: 좌측 콘텐츠, 우측 시간 -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE -->
            <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                <!-- Header Image -->
                <Image Source="pack://application:,,,/Map;component/images/header.png"
                    Width="132"
                    Height="33"
                    Margin="-20, 0,0,0"
                    Stretch="Uniform"/>

                <!-- 헤더 텍스트 -->
                <TextBlock Text="테마열차 관제 및 차량 제어 시스템"
                    Foreground="White"
                    FontSize="22"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="-8,0,0,0"/>
            </StackPanel>

            <!-- RIGHT SIDE  -->
            <TextBlock 
                Grid.Column="1"
                Foreground="White"
                FontSize="20"
                VerticalAlignment="Center"
                Text="{Binding TimeText, RelativeSource={RelativeSource AncestorType=UserControl} , FallbackValue=0000년 00월 00일 - 00:00:00, TargetNullValue=0000년 00월 00일 - 00:00:00 }"/>
        </Grid>
    </Border>
    <!--HEADER END-->
</UserControl>
