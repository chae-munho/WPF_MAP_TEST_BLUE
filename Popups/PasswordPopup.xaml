<Window x:Class="Map.Popups.PasswordPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"

        Width="665"
        Height="365"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
   

    <!-- Root -->
    <Grid x:Name="RootGrid"
          RenderTransformOrigin="0.5,0.5">

        <!-- 해상도 스케일 -->
        <Grid.RenderTransform>
            <ScaleTransform x:Name="PopupScale"
                            ScaleX="1"
                            ScaleY="1"/>
        </Grid.RenderTransform>

     
        <!-- Popup Background -->
        <Border CornerRadius="20">
            <Border.Background>
                <ImageBrush ImageSource="/images/loginpopup2.png"
                            Stretch="Fill"/>
            </Border.Background>
        </Border>

      
        <!-- Content Area -->
      
        <Grid Margin="40">

            <!-- 비밀번호 텍스트 -->
            <TextBlock Text="비밀번호"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="65,60,0,0"/>

            <!-- 비밀번호 입력 박스 -->
            <Border Width="464"
                    Height="53"
                    Background="#33E8FF"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="60,100,0,0">

                <PasswordBox x:Name="PasswordInput"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="16"
                             Padding="15"/>
            </Border>

            <!-- 오류 메시지 -->
            <TextBlock x:Name="ErrorText"
                       Text="잘못 입력된 비밀번호 입니다"
                       Foreground="Red"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="60,160,0,0"
                       Visibility="Collapsed"/>

            <!-- 버튼 영역 -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,0,0">
                <!-- 취소 버튼 -->
                <Button x:Name="CancelButton"
                    Width="100"
                    Height="42"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    BorderThickness="0"
                    Background="#222B4E"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                        CornerRadius="13">
                                <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    취소
                </Button>

                <!-- 확인 버튼 -->
                <Button x:Name="ConfirmButton"
                    Width="100"
                    Height="42"
                    Cursor="Hand"
                    BorderThickness="0"
                    Background="#33E8FF"
                    Foreground="Black"
                    FontSize="18"
                    FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                        CornerRadius="13">
                                <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    확인
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
