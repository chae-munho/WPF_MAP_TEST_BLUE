<Window x:Class="Map.Views.Popups.AdminSettingsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="관리자 설정"
        Width="900"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#222B4E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 서버 주소 -->
        <GroupBox Grid.Row="0"
                  Header="통신 서버 설정"
                  Foreground="White"
                  FontSize="16"
                  FontWeight="Bold"
                  Padding="10"
                  BorderBrush="#4CC3FF">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="서버 주소"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="ServerBaseUrlTextBox"
                         Grid.Column="1"
                         Height="28"
                         VerticalContentAlignment="Center"
                         ToolTip="예: http://192.168.0.173:5090"/>
            </Grid>
        </GroupBox>

        <!-- A/B 설정 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- A면 -->
            <GroupBox Grid.Column="0"
                      Header="가은역 방면 알람 설정"
                      Foreground="White"
                      FontSize="16"
                      FontWeight="Bold"
                      Padding="10"
                      BorderBrush="#4CC3FF">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="항목" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="MIN(최소)" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="MAX(최대)" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="전압" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="AVoltageMinTextBox" Grid.Row="1" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="AVoltageMaxTextBox" Grid.Row="1" Grid.Column="3" Margin="0,3"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="전류" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="ACurrentMinTextBox" Grid.Row="2" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="ACurrentMaxTextBox" Grid.Row="2" Grid.Column="3" Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="배터리용량" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="ABatteryMinTextBox" Grid.Row="3" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="ABatteryMaxTextBox" Grid.Row="3" Grid.Column="3" Margin="0,3" IsEnabled="False"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="배터리온도" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="ABatteryTempMinTextBox" Grid.Row="4" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="ABatteryTempMaxTextBox" Grid.Row="4" Grid.Column="3" Margin="0,3"/>
                </Grid>
            </GroupBox>

            <!-- B면 -->
            <GroupBox Grid.Column="2"
                      Header="구량리역 방면 알람 설정"
                      Foreground="White"
                      FontSize="16"
                      FontWeight="Bold"
                      Padding="10"
                      BorderBrush="#4CC3FF">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="항목" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="MIN(최소)" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="MAX(최대)" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="전압" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="BVoltageMinTextBox" Grid.Row="1" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="BVoltageMaxTextBox" Grid.Row="1" Grid.Column="3" Margin="0,3"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="전류" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="BCurrentMinTextBox" Grid.Row="2" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="BCurrentMaxTextBox" Grid.Row="2" Grid.Column="3" Margin="0,3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="배터리용량" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="BBatteryMinTextBox" Grid.Row="3" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="BBatteryMaxTextBox" Grid.Row="3" Grid.Column="3" Margin="0,3" IsEnabled="False"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="배터리온도" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="BBatteryTempMinTextBox" Grid.Row="4" Grid.Column="1" Margin="0,3"/>
                    <TextBox x:Name="BBatteryTempMaxTextBox" Grid.Row="4" Grid.Column="3" Margin="0,3"/>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="저장"
                    Width="100"
                    Height="36"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="취소"
                    Width="100"
                    Height="36"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>